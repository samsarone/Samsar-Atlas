PORT=8080
PUBLIC_BASE_URL=https://samsar-atlas.example.com

# Point this at samsar_processor. The value may include or omit /v1.
SAMSAR_API_BASE_URL=https://api.samsar.one

# Required platform service credential. Atlas never forwards caller Samsar credentials.
SAMSAR_API_KEY=

SAMSAR_REQUEST_TIMEOUT_MS=60000
JSON_BODY_LIMIT=25mb
AGENT_CARD_DOCUMENTATION_URL=https://docs.samsar.one/v2

# Atlas-managed agent sub-account settings.
ATLAS_AGENT_PROVIDER=samsar-atlas
ATLAS_AGENT_SECRET_BYTES=32

# Use firestore on Cloud Run and memory for local development.
ATLAS_STATE_BACKEND=memory
GOOGLE_CLOUD_PROJECT=
FIRESTORE_DATABASE_ID=
FIRESTORE_AGENT_COLLECTION=samsar_atlas_agents
